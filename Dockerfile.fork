ARG BASE_IMAGE
FROM ${BASE_IMAGE}

USER root

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        libgtk-3-0 \
        libdbus-glib-1-2 \
        postgresql-client \
        sudo && \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g camoufox-cli

COPY --chmod=0440 docker/sudoers.hermes /etc/sudoers.d/hermes

USER hermes
