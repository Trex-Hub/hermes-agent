ARG BASE_IMAGE
FROM ${BASE_IMAGE}

USER root
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        libgtk-3-0 \
        libdbus-glib-1-2 \
        postgresql-client \
        sudo && \
    rm -rf /var/lib/apt/lists/* && \
    printf '%s\n' \
      '# Package installation only (no remove/purge/autoremove)' \
      'hermes ALL=(ALL) NOPASSWD: /usr/bin/apt-get update *' \
      'hermes ALL=(ALL) NOPASSWD: /usr/bin/apt-get install *' \
      '# Python / Node global installs only (no uninstall)' \
      'hermes ALL=(ALL) NOPASSWD: /usr/local/bin/pip install *' \
      'hermes ALL=(ALL) NOPASSWD: /usr/bin/npm install -g *' \
      '# Filesystem additions only (no rm/rmdir/mv)' \
      'hermes ALL=(ALL) NOPASSWD: /bin/mkdir *' \
      'hermes ALL=(ALL) NOPASSWD: /usr/bin/tee *' \
      'hermes ALL=(ALL) NOPASSWD: /bin/ln -s *' \
      '# Self-ownership only' \
      'hermes ALL=(ALL) NOPASSWD: /bin/chown hermes\:hermes *' \
      > /etc/sudoers.d/hermes && \
    chmod 0440 /etc/sudoers.d/hermes

USER hermes
